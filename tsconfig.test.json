{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "lib": ["ES2025", "ESNext.Array", "ESNext.Error"],
    "types": ["vitest/globals", "node"],
    "composite": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "files": ["package.json"],
  "include": [
    "**/*.test.*",
    "**/*.spec.*",
    "types/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "vitest.config.ts",
    "vitest.config.mts",
    "vite.config.ts",
    "vite.config.mts"
  ],
  "exclude": ["node_modules", "dist"]
}
