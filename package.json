{
  "name": "worktree-add",
  "version": "1.0.0",
  "description": "Create a Git worktree next to your current repo for a branch, copy useful local files, install deps, and open it in your apps.",
  "keywords": [
    "cli",
    "development",
    "git",
    "git-worktree",
    "workflow",
    "worktree"
  ],
  "homepage": "https://github.com/Jercik/worktree-add#readme",
  "bugs": {
    "url": "https://github.com/Jercik/worktree-add/issues"
  },
  "license": "MIT",
  "author": "Łukasz Jerciński",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jercik/worktree-add.git"
  },
  "bin": {
    "worktree-add": "bin/worktree-add"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.app.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "format": "oxfmt --config .oxfmtrc.json .",
    "format:check": "oxfmt --check --config .oxfmtrc.json .",
    "fta": "fta-check",
    "knip": "knip",
    "lint": "oxlint --deny-warnings --report-unused-disable-directives .",
    "prepack": "pnpm run rebuild",
    "prepare": "git config core.hooksPath .githooks",
    "rebuild": "pnpm run clean && pnpm run build",
    "start": "node bin/worktree-add",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsgo -b --noEmit"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^15.0.0",
    "commander": "^15.0.0",
    "open": "^11.0.0",
    "package-manager-detector": "^1.6.0",
    "trash": "^10.1.1"
  },
  "devDependencies": {
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^25.9.2",
    "@typescript/native-preview": "beta",
    "@vitest/coverage-v8": "^4.1.8",
    "fta-check": "^1.5.2",
    "fta-cli": "^3.0.0",
    "knip": "^6.16.1",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "oxlint-config-j4k": "^2.7.2",
    "oxlint-tsgolint": "^0.23.0",
    "semantic-release": "^25.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.6.0"
}
