{
  "scripts": {
    "prepack": "pnpm run rebuild",
    "prepare": "git config core.hooksPath .githooks",
    "build": "tsc -p tsconfig.app.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fta": "fta-check",
    "knip": "knip",
    "lint": "eslint",
    "rebuild": "pnpm run clean && pnpm run build",
    "start": "pnpm run rebuild && node bin/worktree-add",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit"
  },
  "name": "worktree-add",
  "author": "Łukasz Jerciński",
  "license": "MIT",
  "version": "1.0.0",
  "description": "Create a Git worktree next to your current repo for a branch, copy useful local files, install deps, and open it in your apps.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jercik/worktree-add.git"
  },
  "homepage": "https://github.com/Jercik/worktree-add#readme",
  "bugs": {
    "url": "https://github.com/Jercik/worktree-add/issues"
  },
  "type": "module",
  "bin": {
    "worktree-add": "bin/worktree-add"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "git",
    "worktree",
    "cli",
    "workflow",
    "git-worktree",
    "development"
  ],
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=22.19.0"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "commander": "^14.0.3",
    "open": "^11.0.0",
    "package-manager-detector": "^1.6.0",
    "trash": "^10.1.1"
  },
  "devDependencies": {
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^10.2.0",
    "eslint-config-axkit": "^1.6.0",
    "fta-check": "^1.5.1",
    "fta-cli": "^3.0.0",
    "knip": "^6.3.0",
    "prettier": "3.8.1",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
